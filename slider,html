          <li>📍 Ahmedabad, India</li>
        </ul>
      </div>

      <div class="section">
        <h2>Skills</h2>

        <div class="skills">
          <span>HTML</span>
          <span>CSS</span>
          <span>JavaScript</span>
          <span>React</span>
          <span>Bootstrap</span>
        </div>
      </div>

      <div class="section">
        <h2>Education</h2>

        <ul>
          <li>
            <strong>BCA</stron 
              g><br>
            XYZ University<br>
            2021 - 2024
          </li>
        </ul>
      </div>

    </div>

    <!-- Right Section -->
    <div class="ri
    
    ht">

